---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="School Calendar">
	<div class="prose prose-lg prose-zinc max-w-none text-zinc-600 leading-relaxed space-y-8">
		<p class="text-xl text-zinc-700 font-medium leading-relaxed">
			Stay up-to-date with the latest events, school holidays, and community activities at Lanor JMS.
		</p>
		
		<div class="bg-white border border-zinc-100 rounded-[2.5rem] shadow-2xl shadow-zinc-200/50 overflow-hidden mt-12">
			<div class="bg-lanor-green p-10 text-white flex items-center justify-between">
				<h2 class="text-3xl font-bold tracking-tight">March 2026</h2>
				<div class="flex gap-2">
					<button class="p-2 hover:bg-white/10 rounded-lg transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
					</button>
					<button class="p-2 hover:bg-white/10 rounded-lg transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
					</button>
				</div>
			</div>
			<div class="p-10">
				<div class="grid grid-cols-7 gap-4 text-center font-bold text-zinc-400 uppercase tracking-widest text-[10px] mb-8">
					<div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
				</div>
				<div class="grid grid-cols-7 gap-4 text-center">
					{Array.from({ length: 31 }, (_, i) => (
						<div key={i + 1} class={`aspect-square flex flex-col items-center justify-center rounded-2xl border border-zinc-50 hover:bg-green-50 transition-all cursor-pointer relative group ${i + 1 === 20 ? 'bg-green-50 border-green-100' : ''}`}>
							<span class="text-lg font-bold text-zinc-600 group-hover:text-lanor-green">{i + 1}</span>
							{i + 1 === 16 && <div class="absolute bottom-3 left-1/2 -translate-x-1/2 w-1.5 h-1.5 bg-lanor-gold rounded-full" />}
							{i + 1 === 20 && <div class="absolute bottom-3 left-1/2 -translate-x-1/2 w-1.5 h-1.5 bg-lanor-green-dark rounded-full" />}
						</div>
					))}
				</div>
			</div>
		</div>

		<div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-8">
			<div class="p-8 bg-amber-50 rounded-3xl border border-amber-100 flex gap-6 items-start">
				<div class="p-4 bg-white rounded-2xl text-amber-600 shadow-sm">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
				</div>
				<div>
					<h3 class="text-xl font-bold text-amber-900 mb-2">March Break</h3>
					<p class="text-amber-800/70 text-sm">March 16 - 20, 2026. No school for students.</p>
				</div>
			</div>
			<div class="p-8 bg-green-50 rounded-3xl border border-green-100 flex gap-6 items-start">
				<div class="p-4 bg-white rounded-2xl text-lanor-green shadow-sm">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
				</div>
				<div>
					<h3 class="text-xl font-bold text-lanor-green-dark mb-2">Grocery Gift Card Drive</h3>
					<p class="text-lanor-green-dark/70 text-sm">March 23 - 27, 2026. Supporting our community.</p>
				</div>
			</div>
		</div>
	</div>
</PageLayout>
