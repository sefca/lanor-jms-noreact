---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, getEntries } from 'astro:content';

const posts = await getCollection('updates');
const authors = await getCollection('authors');

// Map authors
const authorMap = Object.fromEntries(authors.map(author => [author.filePath, author.data]));

// Sort posts by date descending
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Featured post is the most recent one
const featuredPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};

// Get unique categories
const categories = [...new Set(sortedPosts.map(post => post.data.category).filter(Boolean))];
---

<PageLayout title="School Updates" hideHeader={true}>
  <div class="space-y-16">
    {/* Header Section */}
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-2xl">
        <p class="text-xl text-zinc-600 leading-relaxed">
          The latest news, announcements, and stories from the Lanor Junior Middle School community.
        </p>
      </div>
      
      {/* Simple Search/Filter UI (Visual only for now) */}
      <div class="flex flex-wrap gap-3">
        <div class="relative">
          <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 w-[18px] h-[18px]"></i>
          <input 
            type="text" 
            placeholder="Search updates..." 
            class="pl-12 pr-6 py-3 bg-zinc-50 border border-zinc-100 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-lanor-green/20 focus:border-lanor-green transition-all w-64"
          />
        </div>
        <button class="flex items-center gap-2 px-6 py-3 bg-zinc-50 border border-zinc-100 rounded-full text-sm font-bold text-zinc-600 hover:bg-zinc-100 transition-all">
          <i data-lucide="filter" class="w-4 h-4"></i>
          Filter
        </button>
      </div>
    </div>

    {/* Featured Post */}
    {featuredPost && (
      <section class="relative group">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 bg-white rounded-[3rem] border border-zinc-100 overflow-hidden shadow-2xl shadow-lanor-green/5 hover:shadow-lanor-green/10 transition-all duration-500">
          <div class="lg:col-span-7 h-[400px] lg:h-[550px] overflow-hidden relative">
            <img 
              src={featuredPost.data.image || "https://picsum.photos/seed/school/1200/800"} 
              alt={featuredPost.data.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              referrerpolicy="no-referrer"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            {featuredPost.data.category && (
              <div class="absolute top-8 left-8">
                <span class="px-6 py-2 bg-lanor-green text-white text-xs font-black uppercase tracking-widest rounded-full shadow-lg">
                  {featuredPost.data.category}
                </span>
              </div>
            )}
          </div>
          
          <div class="lg:col-span-5 p-10 lg:p-16 flex flex-col justify-center">
            <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-lanor-gold mb-6">
              <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
              {formatDate(featuredPost.data.date)}
              <span class="w-1 h-1 rounded-full bg-zinc-200"></span>
              <span class="text-lanor-green">Featured Story</span>
            </div>
            
            <h2 class="text-3xl lg:text-5xl font-black text-lanor-green-dark mb-6 leading-[1.1] tracking-tight group-hover:text-lanor-green transition-colors">
              <a href={`/updates/${featuredPost.id}`}>
                {featuredPost.data.title}
              </a>
            </h2>
            
            <p class="text-lg text-zinc-600 leading-relaxed mb-10 line-clamp-3">
              {featuredPost.data.description}
            </p>
            
            <div class="flex items-center justify-between pt-8 border-t border-zinc-50">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-zinc-100 flex items-center justify-center text-lanor-green font-bold">
                  {authorMap[featuredPost.data.author.id]?.name.charAt(0)}
                </div>
                <span class="text-sm font-bold text-zinc-500">{authorMap[featuredPost.data.author.id]?.name}</span>
              </div>
              
              <a href={`/updates/${featuredPost.id}`} class="inline-flex items-center gap-2 text-lanor-green font-black text-sm group/link">
                Read Full Story
                <i data-lucide="arrow-right" class="w-5 h-5 group-hover/link:translate-x-2 transition-transform"></i>
              </a>
            </div>
          </div>
        </div>
      </section>
    )}

    {/* Category Pills */}
    <div class="flex flex-wrap gap-3 py-4">
      <button class="px-6 py-2 bg-lanor-green text-white rounded-full text-xs font-bold uppercase tracking-widest shadow-md">
        All Updates
      </button>
      {categories.map(category => (
        <button class="px-6 py-2 bg-white border border-zinc-100 text-zinc-400 rounded-full text-xs font-bold uppercase tracking-widest hover:border-lanor-green/30 hover:text-lanor-green transition-all">
          {category}
        </button>
      ))}
    </div>

    {/* Remaining Posts Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {remainingPosts.map((post) => (
        <article class="group flex flex-col bg-white rounded-[2.5rem] border border-zinc-100 overflow-hidden hover:border-lanor-green/20 hover:shadow-2xl hover:shadow-lanor-green/5 transition-all duration-500">
          <div class="h-64 overflow-hidden relative">
            <img 
              src={post.data.image || `https://picsum.photos/seed/${post.id}/800/600`} 
              alt={post.data.title} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              referrerpolicy="no-referrer"
            />
            {post.data.category && (
              <div class="absolute top-6 left-6">
                <span class="px-4 py-1.5 bg-white/90 backdrop-blur-md text-lanor-green text-[10px] font-black uppercase tracking-widest rounded-full shadow-sm">
                  {post.data.category}
                </span>
              </div>
            )}
          </div>
          
          <div class="p-8 flex flex-col flex-grow">
            <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-4">
              <i data-lucide="calendar" class="w-3 h-3 text-lanor-gold"></i>
              {formatDate(post.data.date)}
            </div>
            
            <h3 class="text-xl font-bold text-lanor-green-dark mb-4 group-hover:text-lanor-green transition-colors leading-snug">
              <a href={`/updates/${post.id}`}>
                {post.data.title}
              </a>
            </h3>
            
            <p class="text-zinc-500 text-sm leading-relaxed mb-8 line-clamp-3">
              {post.data.description}
            </p>
            
            <div class="mt-auto pt-6 border-t border-zinc-50 flex items-center justify-between">
              <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">
                By {authorMap[post.data.author.id]?.name}
              </span>
              <a href={`/updates/${post.id}`} class="text-lanor-green font-bold text-xs flex items-center gap-1 group/more">
                Read More
                <i data-lucide="arrow-right" class="w-3.5 h-3.5 group-hover/more:translate-x-1 transition-transform"></i>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    {sortedPosts.length === 0 && (
      <div class="text-center py-32 bg-zinc-50 rounded-[3rem] border-2 border-dashed border-zinc-100">
        <div class="max-w-md mx-auto">
          <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
            <i data-lucide="search" class="text-zinc-200 w-8 h-8"></i>
          </div>
          <h3 class="text-xl font-bold text-zinc-800 mb-2">No updates found</h3>
          <p class="text-zinc-500">We haven't posted any news yet. Please check back later for the latest school updates!</p>
        </div>
      </div>
    )}

    {/* Newsletter Signup (Visual only) */}
    <div class="bg-lanor-green-dark rounded-[3rem] p-12 lg:p-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="relative z-10 max-w-2xl">
        <h2 class="text-3xl lg:text-5xl font-black text-white mb-6 leading-tight">
          Stay in the loop with our newsletter.
        </h2>
        <p class="text-green-100/80 text-lg mb-10">
          Get the latest school news, event reminders, and important announcements delivered straight to your inbox.
        </p>
        <form class="flex flex-col sm:flex-row gap-4">
          <input 
            type="email" 
            placeholder="Enter your email address" 
            class="flex-grow px-8 py-5 bg-white/10 border border-white/20 rounded-full text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 transition-all"
          />
          <button class="px-10 py-5 bg-lanor-gold text-lanor-green-dark font-black uppercase tracking-widest rounded-full hover:bg-white transition-all shadow-xl">
            Subscribe
          </button>
        </form>
        <p class="mt-6 text-white/40 text-xs font-medium">
          By subscribing, you agree to receive school communication. You can unsubscribe at any time.
        </p>
      </div>
      
      {/* Decorative Element */}
      <div class="absolute right-0 bottom-0 translate-x-1/4 translate-y-1/4 w-96 h-96 bg-lanor-green rounded-full blur-[100px] opacity-20"></div>
    </div>
  </div>
</PageLayout>
