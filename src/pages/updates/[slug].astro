---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('updates');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Resolve author and get the actual author entry
const authorSlug = post.data.author.id.replace(/^(.*\/)?([^\/]+)\.md?$/, '$2');
const author = await getEntry('authors', authorSlug);

// Resolve category and get the actual category entry
const categorySlug = post.data.category.id.replace(/^(.*\/)?([^\/]+)\.md?$/, '$2');
const category = await getEntry('categories', categorySlug);

// Get related posts (same category, excluding current)
const allPosts = await getCollection('updates');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 2);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};

// Estimate reading time
const readingTime = Math.ceil(post.body?.split(' ').length / 200) || 2;
---

<PageLayout title={post.data.title} hideHeader={true}>
  {/* Reading Progress Bar */}
  <div class="fixed top-0 left-0 w-full h-1 z-[60] pointer-events-none">
    <div id="progress-bar" class="h-full bg-lanor-green w-0 transition-all duration-150"></div>
  </div>

  <article class="max-w-4xl mx-auto">
    {/* Breadcrumbs */}
    <nav class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-8">
      <a href="/" class="hover:text-lanor-green transition-colors">Home</a>
      <i data-lucide="chevron-right" class="w-2.5 h-2.5"></i>
      <a href="/updates" class="hover:text-lanor-green transition-colors">Updates</a>
      <i data-lucide="chevron-right" class="w-2.5 h-2.5"></i>
      <span class="text-lanor-gold truncate max-w-[200px]">{post.data.title}</span>
    </nav>

    {/* Header Section */}
    <header class="mb-12">
      {post.data.category && (
        <span class="inline-block px-4 py-1.5 bg-green-50 text-lanor-green text-[10px] font-black uppercase tracking-widest rounded-full mb-6">
          {category.data.name}
        </span>
      )}
      
      <h1 class="text-4xl md:text-6xl font-black text-lanor-green-dark mb-8 leading-[1.1] tracking-tight">
        {post.data.title}
      </h1>

      <div class="flex flex-wrap items-center gap-y-4 gap-x-8 text-xs font-bold uppercase tracking-widest text-zinc-400">
        <div class="flex items-center gap-2">
          {author?.data.avatar ? (
            <img src={author.data.avatar} alt={author.data.name} class="w-8 h-8 rounded-full object-cover border border-zinc-100" referrerpolicy="no-referrer" />
          ) : (
            <div class="w-8 h-8 rounded-full bg-zinc-100 flex items-center justify-center text-lanor-green">
              <i data-lucide="user" class="w-3.5 h-3.5"></i>
            </div>
          )}
          <span class="text-zinc-600">{author?.data.name || 'Lanor JMS'}</span>
        </div>
        
        <div class="flex items-center gap-2">
          <i data-lucide="calendar" class="w-3.5 h-3.5 text-lanor-gold"></i>
          {formatDate(post.data.date)}
        </div>

        <div class="flex items-center gap-2">
          <i data-lucide="clock" class="w-3.5 h-3.5 text-lanor-green"></i>
          {readingTime} min read
        </div>
      </div>
    </header>

    {/* Featured Image */}
    {post.data.image && (
      <div class="mb-16 rounded-[3rem] overflow-hidden shadow-2xl shadow-lanor-green/10 relative group">
        <img 
          src={post.data.image} 
          alt={post.data.title} 
          class="w-full h-auto object-cover max-h-[600px]"
          referrerpolicy="no-referrer"
        />
        <div class="absolute inset-0 ring-1 ring-inset ring-black/10 rounded-[3rem]"></div>
      </div>
    )}

    {/* Content Grid */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      {/* Main Content */}
      <div class="lg:col-span-8">
        <div class="prose prose-lg prose-zinc max-w-none 
          prose-headings:text-lanor-green-dark prose-headings:font-black prose-headings:tracking-tight
          prose-p:text-zinc-600 prose-p:leading-relaxed
          prose-a:text-lanor-green prose-a:font-bold prose-a:no-underline hover:prose-a:underline
          prose-strong:text-lanor-green-dark prose-strong:font-black
          prose-blockquote:border-l-4 prose-blockquote:border-lanor-gold prose-blockquote:bg-zinc-50 prose-blockquote:py-4 prose-blockquote:px-8 prose-blockquote:rounded-r-3xl prose-blockquote:italic prose-blockquote:text-zinc-700
          prose-img:rounded-[2rem] prose-img:shadow-lg
          prose-ul:list-disc prose-ul:marker:text-lanor-gold
          prose-ol:list-decimal prose-ol:marker:text-lanor-gold
          prose-li:text-zinc-600
          prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl
        ">
          <Content />
        </div>

        {/* Share & Tags */}
        <div class="mt-16 pt-12 border-t border-zinc-100 flex flex-wrap items-center justify-between gap-8">
          <div class="flex items-center gap-4">
            <span class="text-[10px] font-black uppercase tracking-widest text-zinc-400">Share this story</span>
            <div class="flex gap-2">
              <button class="w-10 h-10 bg-zinc-50 rounded-full flex items-center justify-center text-zinc-400 hover:text-lanor-green hover:bg-green-50 transition-all">
                <i data-lucide="share-2" class="w-4 h-4"></i>
              </button>
            </div>
          </div>

          <a href="/updates" class="inline-flex items-center gap-2 px-8 py-4 bg-lanor-green-dark text-white rounded-full font-bold text-sm hover:bg-lanor-green transition-all shadow-lg shadow-lanor-green/20 group">
            <i data-lucide="arrow-left" class="w-4.5 h-4.5 group-hover:-translate-x-1 transition-transform"></i>
            Back to All Updates
          </a>
        </div>
      </div>

      {/* Sidebar */}
      <aside class="lg:col-span-4 space-y-12">
        {/* About Author */}
        <div class="bg-zinc-50 rounded-[2.5rem] p-8 border border-zinc-100">
          <h3 class="text-xs font-black uppercase tracking-widest text-lanor-green-dark mb-6">About the Author</h3>
          <div class="flex items-center gap-4 mb-6">
            {author?.data.avatar && (
              <img src={author.data.avatar} alt={author.data.name} class="w-16 h-16 rounded-2xl object-cover shadow-sm" referrerpolicy="no-referrer" />
            )}
            <div>
              <h4 class="font-bold text-zinc-800">{author?.data.name}</h4>
              <p class="text-[10px] font-bold text-lanor-gold uppercase tracking-widest">{author?.data.role}</p>
            </div>
          </div>
          <p class="text-sm text-zinc-500 leading-relaxed mb-6">
            {author?.data.bio || "Lanor Junior Middle School is a vibrant community dedicated to excellence in education, athletics, and the arts."}
          </p>
          {author?.data.link && (
          <a href={author?.data.link} class="text-lanor-green font-bold text-xs flex items-center gap-1 hover:gap-2 transition-all">
            Learn More <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
          </a>
          )}
        </div>

        {/* Related Posts */}
        {relatedPosts.length > 0 && (
          <div class="space-y-6">
            <h3 class="text-xs font-black uppercase tracking-widest text-lanor-green-dark px-2">Related Updates</h3>
            <div class="space-y-4">
              {relatedPosts.map(p => (
                <a href={`/updates/${p.id}`} class="group block p-4 bg-white border border-zinc-100 rounded-3xl hover:border-lanor-green/20 hover:shadow-xl hover:shadow-lanor-green/5 transition-all">
                  <span class="block text-[10px] font-bold text-lanor-gold uppercase tracking-widest mb-2">{formatDate(p.data.date)}</span>
                  <h4 class="text-sm font-bold text-zinc-800 group-hover:text-lanor-green transition-colors line-clamp-2 leading-snug">{p.data.title}</h4>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* Newsletter CTA */}
        <div class="bg-lanor-gold/10 rounded-[2.5rem] p-8 border border-lanor-gold/20">
          <h3 class="text-xs font-black uppercase tracking-widest text-lanor-green-dark mb-4">Stay Updated</h3>
          <p class="text-sm text-zinc-600 mb-6">Get the latest school news delivered to your inbox.</p>
          <button class="w-full py-4 bg-lanor-green-dark text-white rounded-full font-bold text-xs uppercase tracking-widest hover:bg-lanor-green transition-all shadow-md">
            Subscribe
          </button>
        </div>
      </aside>
    </div>
  </article>

  <script>
    // Reading progress bar logic
    window.addEventListener('scroll', () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const progressBar = document.getElementById('progress-bar');
      if (progressBar) {
        progressBar.style.width = scrolled + '%';
      }
    });
  </script>
</PageLayout>
