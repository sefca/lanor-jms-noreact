---
import PageLayout from '../layouts/PageLayout.astro';

const schedule = [
  { period: "School Begins", time: "8:45 AM" },
  { period: "Morning Recess", time: "10:10 AM - 10:25 AM" },
  { period: "Lunch", time: "11:30 AM - 12:30 PM" },
  { period: "Afternoon Recess", time: "1:55 PM - 2:10 PM" },
  { period: "Dismissal", time: "3:15 PM" },
];

const values = [
  { 
    title: "Academic Excellence", 
    description: "Fostering a love for learning through a rigorous and engaging curriculum tailored to JK-8 students.",
    icon: "book-open" 
  },
  { 
    title: "Inclusive Community", 
    description: "Celebrating diversity and ensuring every student feels safe, valued, and respected.",
    icon: "heart" 
  },
  { 
    title: "Leadership & Growth", 
    description: "Developing future leaders through athletics, arts, and community service opportunities.",
    icon: "shield-check" 
  }
];
---

<PageLayout title="School Information | Lanor JMS">
  <div class="max-w-6xl mx-auto px-6 py-12">
    {/* Hero Section */}
    <header class="mb-20 text-center">
      <h1 class="text-5xl md:text-7xl font-black text-lanor-green-dark mb-6 tracking-tight">
        Our School
      </h1>
      <p class="text-xl text-zinc-600 max-w-3xl mx-auto leading-relaxed">
        Lanor Junior Middle School is a vibrant learning community in Etobicoke, serving students from Junior Kindergarten to Grade 8. We are committed to fostering academic excellence and personal growth.
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-24">
      {/* School Day Schedule - Technical Recipe */}
      <div class="lg:col-span-2 bg-white rounded-[2.5rem] border border-zinc-100 shadow-xl shadow-lanor-green/5 overflow-hidden">
        <div class="p-8 border-b border-zinc-100 bg-zinc-50/50 flex items-center justify-between">
          <h2 class="text-xl font-black text-lanor-green-dark flex items-center gap-3">
            <i data-lucide="clock" class="text-lanor-gold"></i>
            School Day Schedule
          </h2>
          <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Standard TDSB Hours</span>
        </div>
        <div class="p-4">
          {schedule.map((item, index) => (
            <div class={`flex items-center justify-between p-6 rounded-2xl transition-colors ${index % 2 === 0 ? 'bg-white' : 'bg-zinc-50/30'}`}>
              <span class="font-bold text-zinc-700">{item.period}</span>
              <span class="font-mono text-lanor-green font-bold bg-green-50 px-4 py-1 rounded-full text-sm">
                {item.time}
              </span>
            </div>
          ))}
        </div>
        <div class="p-6 bg-lanor-green-dark text-white text-center">
          <p class="text-xs font-bold uppercase tracking-widest opacity-80">Please ensure students arrive by 8:40 AM</p>
        </div>
      </div>

      {/* Quick Info Sidebar */}
      <div class="space-y-8">
        <div class="bg-lanor-gold/10 rounded-[2.5rem] p-8 border border-lanor-gold/20">
          <h3 class="text-lg font-black text-lanor-green-dark mb-6 flex items-center gap-2">
            <i data-lucide="graduation-cap" class="w-5 h-5"></i>
            School Profile
          </h3>
          <ul class="space-y-4">
            <li class="flex justify-between items-center border-b border-lanor-gold/10 pb-2">
              <span class="text-sm font-bold text-zinc-500 uppercase tracking-wider">Grades</span>
              <span class="font-bold text-lanor-green-dark">JK - Grade 8</span>
            </li>
            <li class="flex justify-between items-center border-b border-lanor-gold/10 pb-2">
              <span class="text-sm font-bold text-zinc-500 uppercase tracking-wider">Principal</span>
              <span class="font-bold text-lanor-green-dark">B. Mah</span>
            </li>
            <li class="flex justify-between items-center border-b border-lanor-gold/10 pb-2">
              <span class="text-sm font-bold text-zinc-500 uppercase tracking-wider">School Code</span>
              <span class="font-bold text-lanor-green-dark">2052</span>
            </li>
          </ul>
        </div>

        <div class="bg-zinc-900 rounded-[2.5rem] p-8 text-white">
          <h3 class="text-lg font-black mb-6 flex items-center gap-2">
            <i data-lucide="map-pin" class="w-5 h-5 text-lanor-gold"></i>
            Location
          </h3>
          <p class="text-zinc-400 text-sm leading-relaxed mb-6">
            450 Lanor Avenue<br />
            Etobicoke, ON<br />
            M8C 3A1
          </p>
          <div class="space-y-3">
            <a href="tel:4163947680" class="flex items-center gap-3 text-sm font-bold hover:text-lanor-gold transition-colors">
              <i data-lucide="phone" class="w-4 h-4"></i> (416) 394-7680
            </a>
            <a href="mailto:Lanor@tdsb.on.ca" class="flex items-center gap-3 text-sm font-bold hover:text-lanor-gold transition-colors">
              <i data-lucide="mail" class="w-4 h-4"></i> Lanor@tdsb.on.ca
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Values Section */}
    <section class="mb-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-black text-lanor-green-dark mb-4">Our Core Values</h2>
        <div class="w-20 h-1.5 bg-lanor-gold mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map(value => (
          <div class="bg-white p-10 rounded-[3rem] border border-zinc-100 hover:border-lanor-green/20 hover:shadow-2xl hover:shadow-lanor-green/5 transition-all group">
            <div class="w-16 h-16 bg-green-50 rounded-2xl flex items-center justify-center text-lanor-green mb-8 group-hover:scale-110 transition-transform">
              <i data-lucide={value.icon} class="w-8 h-8"></i>
            </div>
            <h3 class="text-xl font-black text-lanor-green-dark mb-4">{value.title}</h3>
            <p class="text-zinc-500 leading-relaxed text-sm">{value.description}</p>
          </div>
        ))}
      </div>
    </section>

    {/* Principal's Message */}
    <section class="bg-zinc-50 rounded-[4rem] p-12 md:p-20 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-lanor-gold/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
        <div class="w-48 h-48 rounded-[2rem] overflow-hidden shadow-xl border-4 border-white">
          <img 
            src="https://picsum.photos/seed/principal/400/400" 
            alt="Principal B. Mah" 
            class="w-full h-full object-cover"
            referrerpolicy="no-referrer"
          />
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <i data-lucide="user" class="text-lanor-gold w-5 h-5"></i>
            <span class="text-xs font-black uppercase tracking-widest text-lanor-green">Leadership Message</span>
          </div>
          <h2 class="text-3xl font-black text-lanor-green-dark mb-6">Welcome from Principal Mah</h2>
          <blockquote class="text-lg text-zinc-600 italic leading-relaxed mb-8">
            "At Lanor JMS, we believe in nurturing the whole child. Our dedicated staff works tirelessly to provide a safe, inclusive, and challenging environment where every student can thrive academically and socially. We are proud of our school community and the achievements of our Lynx!"
          </blockquote>
          <p class="font-black text-lanor-green-dark">— B. Mah, Principal</p>
        </div>
      </div>
    </section>
  </div>
</PageLayout>
