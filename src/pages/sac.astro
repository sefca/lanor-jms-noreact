---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="School Advisory Council (SAC)">
	<div class="prose prose-lg prose-zinc max-w-none text-zinc-600 leading-relaxed space-y-8">
		<p class="text-xl text-zinc-700 font-medium leading-relaxed">
			The Lanor School Advisory Council (SAC) is a dedicated group of parents, teachers, and community members who work together to support and enhance the educational experience of our students.
		</p>
		
		<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-16">
			<div>
				<h2 class="text-3xl font-bold text-lanor-green mb-6">Our Role</h2>
				<p>
					The SAC provides a forum for parents and community members to share their perspectives and advice on school-related matters. We work closely with the school administration to support school initiatives, organize fundraisers, and foster a strong sense of community.
				</p>
			</div>
			<div>
				<h2 class="text-3xl font-bold text-lanor-green mb-6">Get Involved</h2>
				<p>
					All parents and guardians of Lanor students are welcome to attend our monthly meetings. Your voice and participation are vital to our school's success!
				</p>
			</div>
		</div>

		<div class="mt-16 p-10 bg-zinc-50 rounded-[2.5rem] border border-zinc-100 flex flex-col md:flex-row gap-10 items-center">
			<div class="w-24 h-24 bg-white rounded-3xl flex items-center justify-center text-lanor-green shadow-sm border border-zinc-100 shrink-0">
				<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
			</div>
			<div class="flex-1">
				<h3 class="text-2xl font-bold text-lanor-green-dark mb-4">Next Meeting</h3>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
					<div>
						<div class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mb-1">Date</div>
						<div class="font-bold text-zinc-700">Tuesday, April 7, 2026</div>
					</div>
					<div>
						<div class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mb-1">Time</div>
						<div class="font-bold text-zinc-700">6:30 PM</div>
					</div>
					<div>
						<div class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mb-1">Location</div>
						<div class="font-bold text-zinc-700">School Library / Zoom</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</PageLayout>
