---
import logo from '../assets/lanor-lynx-logo.webp';

interface Props {
	title: string;
}

const { title } = Astro.props;
const logoSrc = (logo as any).src || logo;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Lanor Junior Middle School - A vibrant community of learners and leaders." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Preload LCP Image -->
		<link rel="preload" as="image" href={logoSrc} fetchpriority="high" />

		<!-- <link rel="preconnect" href="https://fonts.googleapis.com"> -->
		<!-- <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> -->
		<!-- <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"> -->
		<title>{title}</title>
	</head>
	<body class="font-sans antialiased text-zinc-900 bg-white selection:bg-blue-100 selection:text-blue-900">
		<slot />
		<script>
			import { createIcons, icons } from 'lucide';
			createIcons({ icons });
		</script>
	</body>
</html>
<style is:global>
	@import "../index.css";
	
	:root {
		/* --font-sans: 'Inter', system-ui, -apple-system, sans-serif; */
		--font-sans: system-ui, -apple-system, sans-serif;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: var(--font-sans);
	}
</style>
