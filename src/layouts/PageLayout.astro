---
import Layout from './Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
	title: string;
	hideHeader?: boolean;
}

const { title, hideHeader = false } = Astro.props;
---

<Layout title={title}>
	<Header />
	
	<main class="pt-20">
		{/* Page Header Section */}
		{!hideHeader && (
			<div class="relative bg-zinc-50 py-16 md:py-24 overflow-hidden border-b border-zinc-100">
				{/* Background Pattern */}
				<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#1d6d3b 1px, transparent 1px); background-size: 40px 40px;"></div>
				
				<div class="container mx-auto px-6 relative z-10">
					<div class="max-w-4xl mx-auto">
						<h1 class="text-4xl md:text-6xl font-extrabold text-lanor-green-dark tracking-tight leading-tight">
							{title}
						</h1>
					</div>
				</div>
			</div>
		)}

		{/* Main Content Area */}
		<div class="py-16 md:py-24 bg-white min-h-[40vh]">
			<div class="container mx-auto px-6">
				<div class="max-w-4xl mx-auto">
					<slot />
				</div>
			</div>
		</div>
	</main>

	<Footer />
</Layout>
