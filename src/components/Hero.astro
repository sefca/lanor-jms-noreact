---
import logo from '../assets/lanor-lynx-logo.webp';
---

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-white pt-20">
  {/* Background Subtle Pattern */}
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#1d6d3b 1px, transparent 1px); background-size: 40px 40px;"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1 text-center md:text-left animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-lanor-green rounded-full text-xs font-bold uppercase tracking-widest mb-6 border border-green-100">
          <i data-lucide="graduation-cap" class="w-4 h-4"></i>
          Excellence in Education
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold text-lanor-green-dark mb-6 tracking-tight leading-[1.1]">
          Inspiring <span class="text-lanor-green">Learners</span>,<br />
          Building <span class="text-lanor-gold">Leaders</span>.
        </h1>
        <p class="text-xl text-zinc-600 mb-10 leading-relaxed max-w-xl">
          Lanor Junior Middle School provides a nurturing environment where students thrive through innovation, creativity, and community support.
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
          <button class="group px-8 py-4 bg-lanor-green hover:bg-lanor-green-dark text-white rounded-full font-bold transition-all flex items-center gap-2 shadow-lg shadow-lanor-green/20">
            Explore Programs
            <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
          </button>
          <button class="px-8 py-4 bg-white hover:bg-zinc-50 text-lanor-green rounded-full font-bold transition-all border-2 border-green-100">
            School Calendar
          </button>
        </div>
      </div>

      <div class="flex-1 relative">
        <div class="relative z-10 bg-white p-8 rounded-[2rem] shadow-2xl shadow-lanor-green/10 border border-zinc-100">
          <img 
            src={logo.src} 
            alt="Lanor Lynx Logo" 
            class="w-full h-auto max-w-[320px] mx-auto drop-shadow-xl"
            loading="eager"
            referrerpolicy="no-referrer"
          />
          <div class="mt-8 pt-8 border-t border-zinc-100 grid grid-cols-2 gap-4">
            <div class="text-center">
              <div class="text-3xl font-bold text-lanor-green">400+</div>
              <div class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Students</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-lanor-gold">K-8</div>
              <div class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Grades</div>
            </div>
          </div>
        </div>
        {/* Decorative Elements */}
        <div class="absolute -top-6 -right-6 w-24 h-24 bg-lanor-gold/20 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-lanor-green/10 rounded-full blur-3xl"></div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>
