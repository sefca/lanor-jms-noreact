---
const programs = [
  { name: 'Morning Munch', icon: 'apple', description: 'Our morning nutrition program providing healthy snacks to students.', color: 'bg-amber-50 text-amber-700 border-amber-100' },
  { name: 'Subway Lunch', icon: 'sandwich', description: 'Freshly prepared Subway sandwiches available for lunch.', color: 'bg-emerald-50 text-emerald-700 border-emerald-100' },
  { name: 'Lunch Lady', icon: 'utensils', description: 'Nutritious and delicious meals delivered directly to the school.', color: 'bg-rose-50 text-rose-700 border-rose-100' },
  { name: 'Pizza Lunch', icon: 'pizza', description: 'A student favorite! Regular pizza lunch days throughout the term.', color: 'bg-orange-50 text-orange-700 border-orange-100' },
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 text-lanor-gold font-bold text-xs uppercase tracking-widest mb-4">
          <i data-lucide="heart" class="w-4 h-4"></i>
          Healthy Living
        </div>
        <h2 class="text-4xl font-extrabold text-lanor-green-dark mb-4 tracking-tight">Nutrition Programs</h2>
        <p class="text-lg text-zinc-600 leading-relaxed">
          We believe that healthy eating is fundamental to student success. Explore our various nutrition initiatives and lunch programs.
        </p>
      </div>
      <button class="mt-8 md:mt-0 px-6 py-3 bg-lanor-green text-white font-bold rounded-xl hover:bg-lanor-green-dark transition-all flex items-center gap-2 group shadow-lg shadow-lanor-green/10">
        Learn More
        <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {programs.map((program, index) => {
        return (
          <div
            class={`p-8 rounded-[2rem] border ${program.color} hover:shadow-xl hover:shadow-zinc-200 transition-all group relative overflow-hidden animate-scale-in`}
            style={`animation-delay: ${index * 0.1}s`}
          >
            <div class="absolute top-0 right-0 w-24 h-24 bg-white/20 rounded-full -mr-12 -mt-12 transition-transform group-hover:scale-150"></div>
            <div class="p-4 bg-white rounded-2xl mb-6 inline-block shadow-sm group-hover:scale-110 transition-transform">
              <i data-lucide={program.icon} class="w-8 h-8"></i>
            </div>
            <h3 class="text-2xl font-bold mb-3 text-lanor-green-dark">{program.name}</h3>
            <p class="text-zinc-600 mb-6 leading-relaxed text-sm">
              {program.description}
            </p>
            <a
              href={`/nutrition/${program.name.toLowerCase().replace(' ', '-')}`}
              class="inline-flex items-center space-x-2 text-xs font-bold uppercase tracking-widest hover:text-lanor-green transition-colors"
            >
              <span>Details</span>
              <i data-lucide="external-link" class="w-3 h-3"></i>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  .animate-scale-in {
    opacity: 0;
    animation: scaleIn 0.5s ease-out forwards;
  }
</style>
