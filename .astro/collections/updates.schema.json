{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "collection": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "collection"
          ]
        },
        {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "collection": {
              "type": "string"
            }
          },
          "required": [
            "slug",
            "collection"
          ]
        }
      ]
    },
    "image": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "description",
    "author"
  ]
}